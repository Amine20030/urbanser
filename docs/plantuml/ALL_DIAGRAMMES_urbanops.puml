@startuml UrbanOps - Reseau PERT (taches + durees)

title Diagramme PERT simplifie - UrbanOps (chemin critique indicatif)
skinparam handwritten false
skinparam rectangle {
  roundCorner 10
  shadowing false
}

' Noeuds = taches (duree en jours entre parentheses)
rectangle "T1\nAnalyse besoin\n(5 j)" as T1 #E8F4FD
rectangle "T2\nConception\nBDD/API\n(7 j)" as T2 #E8F4FD
rectangle "T3\nBackend\nSpring\n(14 j)" as T3 #FFF4E6
rectangle "T4\nFrontend\nNext.js\n(12 j)" as T4 #FFF4E6
rectangle "T5\nIntegration\nJWT + CORS\n(5 j)" as T5 #E6FFE6
rectangle "T6\nTests JUnit5\nJaCoCo\n(7 j)" as T6 #F0E6FF
rectangle "T7\nDoc Swagger\n(4 j)" as T7 #F5F5F5

' Dependances (PERT : fin-debut)
T1 -down-> T2 : FS
T2 -down-> T3 : FS
T2 -down-> T4 : FS
T3 -down-> T5 : FS
T4 -down-> T5 : FS
T5 -down-> T6 : FS
T6 -down-> T7 : FS

note bottom of T5
  T5 debute apres fin de T3 ET T4
  (chemin critique ~ max(T3,T4)+T5+...)
end note

legend right
  FS = Finish-to-Start
  Durees indicatives (jours ouvrables)
endlegend

@enduml

@startuml UrbanOps - Diagramme de composants

title Diagramme par composants - UrbanOps

skinparam componentStyle rectangle

package "Client" {
  [Navigateur] as BR
  [Application Next.js 14\n(App Router + Axios)] as FE
}

package "Serveur applicatif" {
  [API REST Spring Boot\ncontext-path /api/v1] as API
  [Couche Securite\nJWT + Spring Security] as SEC
  [Couche Metier\nServices transaccionnels] as SVC
  [Couche Persistance\nSpring Data JPA] as REPO
  [Stockage fichiers\nuploads/ UUID] as FS
  [Taches planifiees\n@Scheduled] as SCH
}

database "PostgreSQL\nurbanops_db" as DB

cloud "Google Gemini\nREST generateContent" as GEM
cloud "SMTP\n(JavaMail)" as MAIL

BR --> FE : HTTPS
FE --> API : JSON / multipart\nAuthorization Bearer

API --> SEC
API --> SVC
SVC --> REPO
SVC --> FS
SVC --> GEM : Analyse severite\n(IncidentService)
SVC --> MAIL : Alertes\n(EmailService @Async)
REPO --> DB : JDBC
SCH --> REPO : Stats / incidents\nen retard

note right of API
  Controllers :
  Auth, Incident, User,
  Category, Sector, Stats, Alert
end note

@enduml

@startuml UrbanOps - Sequence creation incident

title Diagramme de sequence - Creation d incident (logique reelle)

actor Citoyen as C
participant "IncidentController" as IC
participant "IncidentService" as IS
participant "CategoryRepository" as CR
participant "SectorRepository" as SR
participant "FileStorageService" as FS
participant "AIAnalysisService" as AI
participant "IncidentRepository" as IR
participant "AlertService" as AS
participant "EmailService" as EM

C -> IC : POST /incidents\nmultipart(data + photo)
IC -> IS : createIncident(request, photo, reporter)

IS -> CR : findById(categoryId)
CR --> IS : Category

IS -> SR : findById(sectorId)
SR --> IS : Sector

opt photo presente
  IS -> FS : storeFile(photo)
  FS --> IS : photoUrl
end

IS -> AI : analyze(description, categoryName)
AI --> IS : AIAnalysisResult\n(severity HIGH/MEDIUM/LOW)

IS -> IR : save(incident)
IR --> IS : Incident (id)

IS -> IR : save(referenceCode)
IR --> IS : Incident persiste

opt severity HIGH ou MEDIUM
  IS -> AS : createAndSendAlert(incident)
  AS -> EM : sendAlertEmail (async)
  AS --> IS : Alert
end

IS --> IC : Incident
IC --> C : 201 IncidentResponse

@enduml
