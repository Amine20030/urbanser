IncidentService --> SectorRepository
IncidentService --> FileStorageService
IncidentService --> AIAnalysisService
IncidentService --> AlertService

UserService --> UserRepository
CategoryService --> CategoryRepository
SectorService --> SectorRepository
StatsService --> IncidentRepository
StatsService --> UserRepository
StatsService --> AlertRepository

